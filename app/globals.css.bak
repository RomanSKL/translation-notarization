@import "tailwindcss";

:root {
  --gold: #c9a84c;
  --gold-light: #e8c97a;
  --gold-dark: #8b6914;
  --dark: #0a0a0f;
  --dark-card: #12121a;
  --dark-border: #1e1e2e;
  --dark-hover: #1a1a28;
  --text-muted: #6b6b8a;
}

* {
  box-sizing: border-box;
}

body {
  background-color: var(--dark);
  color: #e8e8f0;
  font-family: "Georgia", "Times New Roman", serif;
  min-height: 100vh;
}

.gold-gradient {
  background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ornament-line {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ornament-line::before,
.ornament-line::after {
  content: "";
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold-dark), var(--gold), var(--gold-dark), transparent);
}

@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

.shimmer {
  background: linear-gradient(90deg, var(--gold-dark) 25%, var(--gold-light) 50%, var(--gold-dark) 75%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3s linear infinite;
}

@keyframes pulse-gold {
  0%, 100% { box-shadow: 0 0 0 0 rgba(201, 168, 76, 0.2); }
  50% { box-shadow: 0 0 20px 4px rgba(201, 168, 76, 0.15); }
}

.upload-zone {
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.upload-zone::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(201, 168, 76, 0.05) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.upload-zone:hover::before,
.upload-zone.drag-over::before {
  opacity: 1;
}

.upload-zone.drag-over {
  border-color: var(--gold) !important;
  animation: pulse-gold 1.5s ease-in-out infinite;
}

.progress-bar {
  background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light));
  background-size: 200% 100%;
  animation: shimmer 1.5s linear infinite;
}

.btn-primary {
  background: linear-gradient(135deg, var(--gold-dark), var(--gold));
  color: #0a0a0f;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-size: 0.8rem;
  padding: 14px 40px;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn-primary:hover::after {
  opacity: 1;
}

.btn-primary:hover {
  box-shadow: 0 0 30px rgba(201, 168, 76, 0.4);
  transform: translateY(-1px);
}

.btn-primary:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  transform: none;
}

.btn-primary span {
  position: relative;
  z-index: 1;
}

.corner-ornament {
  position: absolute;
  width: 20px;
  height: 20px;
  border-color: var(--gold-dark);
  border-style: solid;
  opacity: 0.6;
}

.corner-ornament.tl { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
.corner-ornament.tr { top: 8px; right: 8px; border-width: 1px 1px 0 0; }
.corner-ornament.bl { bottom: 8px; left: 8px; border-width: 0 0 1px 1px; }
.corner-ornament.br { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--dark-card); }
::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 2px; }
